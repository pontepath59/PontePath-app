{

  "name": "pontepath-app",

  "private": true,

  const express = require("express");

const app = express();

app.get("/", (req, res) => {

  res.send("PontePath is LIVE 🚀");

});

const PORT = process.env.PORT || 3000;

app.listen(PORT, "0.0.0.0", () => {

  console.log("Server running on port " + PORT);

});

  

  "dependencies": {

    "next": "14.0.0",

    "react": "18.2.0",

    "react-dom": "18.2.0"

  }

}
